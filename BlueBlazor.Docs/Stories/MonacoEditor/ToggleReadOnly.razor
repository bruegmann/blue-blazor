@using Microsoft.AspNetCore.Components.Forms

<label>
    <InputCheckbox @bind-Value="ReadOnly" class="form-check-input" /> Read only
</label>

<MonacoEditor Language="xml" @bind-Value="MyCode" ReadOnly="ReadOnly" />

@code {
    private bool ReadOnly { get; set; } = true;
    private string MyCode { get; set; } = "<IDataDocuments>Test</IDataDocuments>";
}
