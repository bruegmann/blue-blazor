@using Microsoft.Extensions.Localization
@namespace BlueBlazor.Components

@inherits BlueBlazor.Internals.DialogBaseParts.DialogBase

@inject IStringLocalizer<BlueBlazor.Resources.Phrases> L

<div class="@_dialogClass" style="transition: max-width .2s">
    <div class="@(new CssBuilder("modal-content").AddClass(ContentClass).Build())">
        <div class="@(new CssBuilder("modal-header").AddClass(HeaderClass).Build())">
            <h1 class="modal-title fs-5" id="@(Id + "-label")">@TitleText @TitleContent</h1>
            <form method="dialog" style="display: contents">
                <button type="submit" class="btn-close" aria-label="@L["Close"]"></button>
            </form>
        </div>
        <div class="@(new CssBuilder("modal-body").AddClass(BodyClass))">
            @BodyContent
        </div>

        @if (FooterContent != null)
        {
            <div class="modal-footer">
                @FooterContent
            </div>
        }
    </div>
</div>