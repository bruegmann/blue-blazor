@namespace BlueBlazor.Components
@inherits BlueComponentBase

<div class="@(new CssBuilder(Class).AddClass("d-none", ReadOnly).Build())" style="@(new StyleBuilder(Style).AddStyle("height", Height).Build())" @ref="@_element" @attributes="@AdditionalAttributes" />
@if (ReadOnly)
{
    <pre @ref="_pre" data-lang="@Language" class="@Class" style="@Style" @attributes="@AdditionalAttributes">@_value</pre>
}